      <column datatype='string' name='[Country Code]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='string' name='[Country Name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='integer' name='[Year]' role='dimension' type='quantitative' />
      <column caption='Arab Group' datatype='string' name='[Calculation_Arab_Group]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country Code] = &quot;LBN&quot; OR [Country Code] = &quot;JOR&quot; OR [Country Code] = &quot;EGY&quot; OR [Country Code] = &quot;TUN&quot; OR [Country Code] = &quot;MAR&quot; OR [Country Code] = &quot;DZA&quot; THEN &quot;Arab&quot; ELSE &quot;Non-Arab&quot; END' />
      </column>
      <column caption='Lebanon Highlight' datatype='string' name='[Calculation_Lebanon_Highlight]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country Code] = &quot;LBN&quot; THEN &quot;Lebanon&quot; ELSE &quot;Comparator&quot; END' />
      </column>
      <column caption='Small Multiples Row' datatype='integer' name='[Calculation_Small_Multiples_Row]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='CASE [Country Code] WHEN &quot;LBN&quot; THEN 1 WHEN &quot;JOR&quot; THEN 1 WHEN &quot;EGY&quot; THEN 1 WHEN &quot;TUN&quot; THEN 1 WHEN &quot;MAR&quot; THEN 2 WHEN &quot;DZA&quot; THEN 2 WHEN &quot;TUR&quot; THEN 2 WHEN &quot;IRN&quot; THEN 2 WHEN &quot;GEO&quot; THEN 3 WHEN &quot;ALB&quot; THEN 3 WHEN &quot;ARM&quot; THEN 3 END' />
      </column>
      <column caption='Small Multiples Column' datatype='integer' name='[Calculation_Small_Multiples_Column]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='CASE [Country Code] WHEN &quot;LBN&quot; THEN 1 WHEN &quot;JOR&quot; THEN 2 WHEN &quot;EGY&quot; THEN 3 WHEN &quot;TUN&quot; THEN 4 WHEN &quot;MAR&quot; THEN 1 WHEN &quot;DZA&quot; THEN 2 WHEN &quot;TUR&quot; THEN 3 WHEN &quot;IRN&quot; THEN 4 WHEN &quot;GEO&quot; THEN 1 WHEN &quot;ALB&quot; THEN 2 WHEN &quot;ARM&quot; THEN 3 END' />
      </column>
      <column caption='Unemployed FLFPR Component' datatype='real' name='[Calculation_Unemployed_FLFPR_Component]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Female Labor Force Participation Rate] - [Employed FLFPR]' />
      </column>
